{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agentPushNotifEnabled": false,
  "disableArtifact": true,
  "disableBundledSkills": true,
  "disableClaudeAiConnectors": true,
  "disableRemoteControl": true,
  "disableWorkflows": true,
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "jdtls-lsp@claude-plugins-official": true,
    "ponytail@ponytail": true,
    "pyright-lsp@claude-plugins-official": true,
    "sonarqube@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "env": {
    "API_TIMEOUT_MS": "1200000",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "1200000",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS": "1",
    "CLAUDE_CODE_DISABLE_OFFICIAL_MARKETPLACE_AUTOINSTALL": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_SIMPLE_SYSTEM_PROMPT": "1",
    "DISABLE_COST_WARNINGS": "1"
  },
  "extraKnownMarketplaces": {
    "ponytail": {
      "source": {
        "repo": "DietrichGebert/ponytail",
        "source": "github"
      }
    },
    "thedotmack": {
      "source": {
        "repo": "thedotmack/claude-mem",
        "source": "github"
      }
    }
  },
  "feedbackSurveyRate": 0,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/notify-ghostty.sh",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "comment-checker",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "rtk hook claude",
            "type": "command"
          },
          {
            "command": "~/.claude/hooks/validate-no-ai-trailer.sh",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "~/.claude/hooks/block-dangerous-git.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/antoinebouteiller/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/stop_caffeinate.sh",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/start_caffeinate.sh",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "model": "claude-fable-5[1m]",
  "permissions": {
    "additionalDirectories": ["~/.claude"],
    "allow": [
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git init *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git status *)",
      "Bash(git commit *)",
      "Bash(cat *)",
      "Bash(du *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(launchctl list *)",
      "Bash(ls *)",
      "Bash(sort *)",
      "Bash(tree *)",
      "Bash(unzip *)",
      "Bash(wc *)",
      "Bash(xxd *)",
      "Bash(xargs *)",
      "Bash(nix build *)",
      "Bash(nix develop *)",
      "Bash(nix eval *)",
      "Bash(nix flake *)",
      "Bash(nix path-info *)",
      "Bash(nix-prefetch-github *)",
      "Bash(nix-prefetch-url *)",
      "Bash(nix-build *)",
      "Bash(brew info *)",
      "Bash(brew search *)",
      "Bash(lsof *)",
      "Bash(open *)",
      "Bash(pbcopy)",
      "Bash(ps *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(vp *)",
      "Bash(npx *)",
      "Bash(uv *)",
      "Read(//nix/store/**)",
      "Read(//tmp/**)",
      "Write(//tmp/**)",
      "Edit(//tmp/**)",
      "WebFetch",
      "WebSearch",
      "mcp__plugin_claude-code-home-manager_fff__grep",
      "mcp__plugin_claude-code-home-manager_fff__find_files"
    ],
    "defaultMode": "auto",
    "deny": [
      "DesignSync",
      "NotebookEdit",
      "SendMessage",
      "PushNotification",
      "RemoteTrigger",
      "ScheduleWakeup",
      "CronCreate",
      "CronDelete",
      "CronList",
      "EnterWorktree",
      "ExitWorktree",
      "ShareOnboardingGuide"
    ]
  },
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "statusLine": {
    "command": "bunx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10,
    "type": "command"
  },
  "tui": "fullscreen"
}
