{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "API_TIMEOUT_MS": "1200000",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "1200000",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS": "1",
    "CLAUDE_CODE_DISABLE_OFFICIAL_MARKETPLACE_AUTOINSTALL": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_SIMPLE_SYSTEM_PROMPT": "1",
    "DISABLE_COST_WARNINGS": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git init *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git status *)",
      "Bash(git commit *)",
      "Bash(cat *)",
      "Bash(du *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(launchctl list *)",
      "Bash(ls *)",
      "Bash(sort *)",
      "Bash(tree *)",
      "Bash(unzip *)",
      "Bash(wc *)",
      "Bash(xxd *)",
      "Bash(xargs *)",
      "Bash(nix build *)",
      "Bash(nix develop *)",
      "Bash(nix eval *)",
      "Bash(nix flake *)",
      "Bash(nix path-info *)",
      "Bash(nix-prefetch-github *)",
      "Bash(nix-prefetch-url *)",
      "Bash(nix-build *)",
      "Bash(brew info *)",
      "Bash(brew search *)",
      "Bash(lsof *)",
      "Bash(open *)",
      "Bash(pbcopy)",
      "Bash(ps *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(vp *)",
      "Bash(npx *)",
      "Bash(uv *)",
      "Read(//nix/store/**)",
      "Read(//tmp/**)",
      "Edit(//tmp/**)",
      "WebFetch",
      "WebSearch",
      "mcp__plugin_claude-code-home-manager_fff__grep",
      "mcp__plugin_claude-code-home-manager_fff__find_files",
      "mcp__plugin_claude-code-home-manager_fff__multi_grep"
    ],
    "deny": [
      "DesignSync",
      "NotebookEdit",
      "SendMessage",
      "PushNotification",
      "RemoteTrigger",
      "ScheduleWakeup",
      "CronCreate",
      "CronDelete",
      "CronList",
      "EnterWorktree",
      "ExitWorktree",
      "ShareOnboardingGuide"
    ],
    "defaultMode": "auto",
    "additionalDirectories": ["~/.claude"]
  },
  "model": "opus[1m]",
  "disableClaudeAiConnectors": true,
  "disableBundledSkills": true,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-ghostty.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "comment-checker"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/strip-ponytail-comments.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/validate-no-ai-trailer.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous-git.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/plan-peer-review-check.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/task-peer-review-check.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/write-peer-review-check.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/antoinebouteiller/.claude/hooks/sonar-secrets/build-scripts/pretool-secrets.sh'",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/peer-review-reminder.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/antoinebouteiller/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop_caffeinate.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-peer-review-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/start_caffeinate.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/user-prompt-check.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/antoinebouteiller/.claude/hooks/sonar-secrets/build-scripts/prompt-secrets.sh'",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "disableRemoteControl": true,
  "disableWorkflows": true,
  "disableArtifact": true,
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "ponytail@ponytail": true,
    "lsp@dotfiles-plugins": true
  },
  "extraKnownMarketplaces": {
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "dotfiles-plugins": {
      "source": {
        "source": "directory",
        "path": "~/.dotfiles/home-manager/applications/agents/claude-code/plugins"
      }
    }
  },
  "feedbackSurveyRate": 0,
  "effortLevel": "medium",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "agentPushNotifEnabled": false,
  "skipAutoPermissionPrompt": true
}
