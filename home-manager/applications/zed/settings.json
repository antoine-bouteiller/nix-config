{
  "agent_servers": {
    
  },
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "diff_view_style": "split",
  "buffer_font_family": "MesloLGM Nerd Font",
  "lsp": {
    "vtsls": {
      "settings": {
        "autoUseWorkspaceTsdk": true,
        "experimental": {
          "completion": {
            "enableServerSideFuzzyMatch": true,
            "entriesLimit": 10,
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "typescript": {
          "preferGoToSourceDefinition": true,
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
          "tsserver": {
            "maxTsServerMemory": 16384,
            "enableTracing": false,
            "log": "off",
          },
        },
      },
    },
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/.worktree",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/node_modules",
  ],
  "languages": {
    "Python": {
      "language_servers": ["!basedpyright", "ruff", "ty", "!pyrefly", "!pyright", "!pylsp", "..."],
    },
    "TSX": {
      "format_on_save": "on",
      "language_servers": ["eslint", "!typescript-language-server", "vtsls", "!oxlint", "!oxfmt", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true,
      },
    },
    "TypeScript": {
      "format_on_save": "on",
      "language_servers": ["eslint", "!typescript-language-server", "vtsls", "!oxlint", "!oxfmt", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true,
      },
    },
    "Astro": {
      "language_servers": ["eslint", "vtsls", "astro-language-server", "!oxlint", "!oxfmt", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true,
      },
    },
    "Nix": {
      "language_servers": ["nixd"],
      "formatter": {
        "external": {
          "command": "alejandra", // or "nixfmt"
          "arguments": ["--quiet", "--"],
        },
      },
    },
    "TOML": {
      "language_servers": [],
      "format_on_save": "off",
    },
  },
  "agent": {
    "dock": "left",
    "default_model": {
      "enable_thinking": true,
      "provider": "google",
      "model": "gemini-2.5-flash",
    },
    "commit_message_model": {
      "provider": "google",
      "model": "gemini-2.5-flash",
    },
    "model_parameters": [],
  },
  "terminal": {
    "font_family": "MesloLGM Nerd Font",
    "font_size": 12,
    "line_height": {
      "custom": 1.4,
    },
  },
  "minimap": {
    "show": "auto",
  },
  "autosave": "on_focus_change",
  "confirm_quit": true,
  "linked_edits": true,
  "preferred_line_length": 160,
  "base_keymap": "VSCode",
  "ui_font_size": 15,
  "buffer_font_size": 14,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Fleet Dark",
  },
  "icon_theme": "Material Icon Theme",
}
