{
  "name": "Essential Tabs for Brave",
  "description": "Smart pinned tab management — offloading, URL locking, and intelligent tab lifecycle for Brave browser",
  "version": "1.0.0",
  "manifest_version": 3,
  "permissions": ["tabs", "webNavigation", "contextMenus", "storage"],
  "icons": {
    "128": "logo.png"
  },
  "background": {
    "service_worker": "essentials-tabs.js"
  },
  "action": {},
  "commands": {
    "_execute_action": {
      "description": "Offload / reset the current tab"
    }
  }
}
