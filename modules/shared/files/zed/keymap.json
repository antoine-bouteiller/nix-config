[
  {
    "context": "Terminal",
    "bindings": {
      "shift-enter": ["terminal::SendText", "\u001b\r"],
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-shift-k": "editor::DeleteLine",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-/": [
        "editor::ToggleComments",
        {
          "advance_downwards": false
        }
      ]
    }
  }
]
